# ===== Security Notice =====
# 1. Copy this file to ops/.env: cp ops/.env.example ops/.env
# 2. Change all default passwords to strong passwords
# 3. Never commit ops/.env to version control!

# ===== LLM Proxy Selection =====
# Which LLM proxy to run: newapi, litellm, or empty (skip LLM proxy entirely)
# Kong always starts regardless; only the llm-proxy container is optional.
LLM_PROXY=

# ===== Redis Configuration =====
# Must match REDIS_PASSWORD in scripts/supabase/.env
REDIS_PASSWORD=CHANGE_ME

# ===== Kong Gateway Configuration =====
KONG_IMAGE=kong:3.9.1
KONG_PG_USER=kong
KONG_PG_PASSWORD=CHANGE_ME
KONG_PG_DATABASE=kong

# ===== NewAPI Configuration (LLM_PROXY=newapi) =====
TZ=Asia/Shanghai
SESSION_SECRET=CHANGE_ME
NEWAPI_DB_USER=newapi
NEWAPI_DB_PASSWORD=CHANGE_ME
NEWAPI_DB_DATABASE=newapi

# ===== LiteLLM Configuration (LLM_PROXY=litellm) =====
# WARNING: LITELLM_DB_PASSWORD must NOT contain @#/:?% (breaks DATABASE_URL)
LITELLM_DB_USER=litellm
LITELLM_DB_PASSWORD=CHANGE_ME
LITELLM_DB_DATABASE=litellm
LITELLM_MASTER_KEY=sk-CHANGE_ME
LITELLM_SALT_KEY=sk-CHANGE_ME

# ===== LLM Provider API Keys =====
DEEPSEEK_API_KEY=CHANGE_ME
QWEN_API_KEY=CHANGE_ME
ZHIPU_API_KEY=CHANGE_ME

# ===== Kong API Key Configuration =====
DEFAULT_API_KEY=CHANGE_ME
PREMIUM_API_KEY=CHANGE_ME

# ===== Kong Deck Variables (used by kong.yml) =====
# Port for Aether API (control plane) — Kong routes to this container
DECK_AETHER_API_PORT=8008
# Port for LLM proxy container (3001 for NewAPI, 4000 for LiteLLM)
DECK_LLM_PROXY_PORT=3001
# Public-facing origin (used in CORS and redirect rewrites)
DECK_PUBLIC_ORIGIN=https://www.example.com
DECK_PUBLIC_HOST=www.example.com
DECK_FORWARDED_PROTO=https
# Lua code for UI redirect rewrite (set to 'return' for no-op)
DECK_UI_REDIRECT_REWRITE=return

# ===== OpenMeter Usage Metering =====
KAFKA_CLUSTER_ID=CHANGE_ME
OPENMETER_API_KEY=
OPENMETER_API_ENDPOINT=http://openmeter:8888
OPENMETER_EVENT_TYPE=litellm_tokens
CLICKHOUSE_PASSWORD=openmeter
OPENMETER_DB_USER=openmeter
OPENMETER_DB_PASSWORD=openmeter
OPENMETER_DB_DATABASE=openmeter

# ===== Public Access Configuration =====
PUBLIC_HOST=www.example.com
# Set to true when SSL certs are in ssl/ directory (start.sh validates they exist)
# Set to false for local dev without SSL.
USE_HTTPS=true
