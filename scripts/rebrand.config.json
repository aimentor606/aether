{
  "brandName": "aether",
  "brandDomain": "aether.dev",
  "brandTitle": "Aether",
  "brandTwitter": "@aether",
  "description": "Brand configuration for rebrand.sh. Override with env vars: BRAND, BRAND_DOMAIN, BRAND_TITLE, BRAND_TWITTER",
  "replacementRules": {
    "keepDirectoryNames": [
      "core/kortix-master",
      "core/aether-master",
      "packages/kortix-ocx-registry"
    ],
    "skipPatterns": [
      "node_modules",
      ".next",
      "dist",
      ".git",
      "pnpm-lock.yaml",
      "coverage",
      "packages/db/drizzle"
    ],
    "excludedPaths": [
      "core/kortix-master/",
      "core/init-scripts/kortix-env-setup.sh",
      "packages/db/drizzle/"
    ]
  }
}
