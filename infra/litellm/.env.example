# LiteLLM Proxy Configuration
# Copy this file to .env and fill in with actual values for deployment

# ==============================================
# LITELLM SERVICE CONFIGURATION
# ==============================================

# Master API key for LiteLLM proxy authentication
LITELLM_MASTER_KEY=your_litellm_master_key_here

# Shared aether PostgreSQL database URL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://aether_user:aether_password@aether-db.example.com:5432/aether

# ==============================================
# REDIS CONFIGURATION (Multi-instance State)
# ==============================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ==============================================
# OPENAI PROVIDER
# ==============================================

OPENAI_API_KEY=sk-...

# ==============================================
# AZURE OPENAI PROVIDER
# ==============================================

AZURE_API_KEY=your_azure_api_key_here
AZURE_API_BASE=https://your-azure-resource.openai.azure.com/

# ==============================================
# ANTHROPIC (CLAUDE) PROVIDER
# ==============================================

ANTHROPIC_API_KEY=sk-ant-...

# ==============================================
# AWS BEDROCK PROVIDER
# ==============================================

AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION_NAME=us-east-1

# ==============================================
# DEEPSEEK PROVIDER
# ==============================================

DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ==============================================
# MINIMAX PROVIDER
# ==============================================

MINIMAX_API_KEY=your_minimax_api_key_here

# ==============================================
# ZHI-PU (GLMC) PROVIDER
# ==============================================

ZHI_PU_API_KEY=your_zhi_pu_api_key_here

# ==============================================
# MOONSHOT (KIMI) PROVIDER
# ==============================================

MOONSHOT_API_KEY=your_moonshot_api_key_here
