{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "noEmit": true,
    "module": "esnext",
    "jsx": "preserve",
    "incremental": true,
    "ignoreDeprecations": "5.0",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@aether/ui": [
        "../../packages/ui/src"
      ],
      "@aether/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@aether/sdk": [
        "../../packages/sdk/src"
      ],
      "@aether/sdk/*": [
        "../../packages/sdk/src/*"
      ],
      "@/*": [
        "./src/*"
      ],
      "@/.source": [
        "./.source"
      ]
    },
    "baseUrl": "."
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    ".next/dev/types/**/*.ts",
    ".source/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
