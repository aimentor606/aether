# ===== Security Notice =====
# 1. Copy this file to ops/.env: cp ops/.env.example ops/.env
# 2. Change all default passwords to strong passwords
# 3. Never commit ops/.env to version control!

# ===== LLM Proxy Selection =====
# Which LLM proxy to run: newapi, litellm, or empty (skip LLM proxy entirely)
# Kong always starts regardless; only the llm-proxy container is optional.
LLM_PROXY=

# ===== Redis Configuration =====
# Must match REDIS_PASSWORD in scripts/supabase/.env
REDIS_PASSWORD=CHANGE_ME

# ===== Kong Gateway Configuration =====
KONG_IMAGE=kong:3.9.1
KONG_PG_USER=kong
KONG_PG_PASSWORD=CHANGE_ME
KONG_PG_DATABASE=kong

# ===== NewAPI Configuration (LLM_PROXY=newapi) =====
TZ=Asia/Shanghai
SESSION_SECRET=CHANGE_ME
NEWAPI_DB_USER=newapi
NEWAPI_DB_PASSWORD=CHANGE_ME
NEWAPI_DB_DATABASE=newapi

# ===== LiteLLM Configuration (LLM_PROXY=litellm) =====
# WARNING: LITELLM_DB_PASSWORD must NOT contain @#/:?% (breaks DATABASE_URL)
LITELLM_DB_USER=litellm
LITELLM_DB_PASSWORD=CHANGE_ME
LITELLM_DB_DATABASE=litellm
LITELLM_MASTER_KEY=sk-CHANGE_ME
LITELLM_SALT_KEY=sk-CHANGE_ME

# ===== LLM Provider API Keys =====
DEEPSEEK_API_KEY=CHANGE_ME
QWEN_API_KEY=CHANGE_ME
ZHIPU_API_KEY=CHANGE_ME

# ===== Kong API Key Configuration =====
DEFAULT_API_KEY=CHANGE_ME
PREMIUM_API_KEY=CHANGE_ME

# ===== Kong Deck Variables (used by kong.yml) =====
# Port for Aether API (control plane) — Kong routes to this container
DECK_AETHER_API_PORT=8008
# Port for LLM proxy container (3001 for NewAPI, 4000 for LiteLLM)
DECK_LLM_PROXY_PORT=3001
# Public-facing origin (used in CORS and redirect rewrites)
DECK_PUBLIC_ORIGIN=https://www.example.com
DECK_PUBLIC_HOST=www.example.com
DECK_FORWARDED_PROTO=https
# Lua code for UI redirect rewrite (set to 'return' for no-op)
DECK_UI_REDIRECT_REWRITE=return

# ===== OpenMeter Usage Metering =====
KAFKA_CLUSTER_ID=CHANGE_ME
OPENMETER_API_KEY=
OPENMETER_API_ENDPOINT=http://openmeter:8888
OPENMETER_EVENT_TYPE=litellm_tokens
CLICKHOUSE_PASSWORD=openmeter
OPENMETER_DB_USER=openmeter
OPENMETER_DB_PASSWORD=openmeter
OPENMETER_DB_DATABASE=openmeter

# ===== Public Access Configuration =====
PUBLIC_HOST=www.example.com
# Set to true when SSL certs are in ssl/ directory (start.sh validates they exist)
# Set to false for local dev without SSL.
USE_HTTPS=true

# ===== Aether API Configuration =====
# These are read by apps/api/.env — the docker-compose mounts that file into
# the API container.  Copy the relevant ones into apps/api/.env.
# See apps/api/.env.example for the full reference.

# REQUIRED: 'local' for self-hosted, 'cloud' for managed SaaS.
# Cloud mode enables billing, OAuth login, managed sandbox providers.
ENV_MODE=cloud
# Deployment tier: dev | staging | prod
# Controls Sentry sampling, schema auto-migration, Stripe price selection.
INTERNAL_AETHER_ENV=prod

# REQUIRED in cloud mode: public-facing API URL used for sandbox routing,
# channel webhooks, and health checks.
AETHER_URL=https://api.example.com/v1/router
# REQUIRED in cloud mode: public-facing frontend URL (CORS, redirects).
FRONTEND_URL=https://www.example.com

# Sandbox provider: local_docker, daytona, justavps (comma-separated).
# Cloud deployments typically use justavps. Self-hosted uses local_docker.
ALLOWED_SANDBOX_PROVIDERS=justavps

# CORS: comma-separated extra origins allowed beyond the built-in list.
# Required for self-hosted deployments with custom domains.
CORS_ALLOWED_ORIGINS=

# Deployments feature (Freestyle integration).
# Also set NEXT_PUBLIC_AETHER_DEPLOYMENTS_ENABLED=true as a frontend build arg.
AETHER_DEPLOYMENTS_ENABLED=false

# Tunnel reverse-proxy (enabled by default).
TUNNEL_ENABLED=true
TUNNEL_SIGNING_SECRET=CHANGE_ME

# ===== Aether API — Secrets (REQUIRED) =====
# These MUST be set in apps/api/.env. The API will refuse to start without them.
# DATABASE_URL=postgresql://postgres:PASSWORD@supabase-db:5432/postgres
# SUPABASE_URL=http://supabase-kong:8000
# SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME
# API_KEY_SECRET=CHANGE_ME

# ===== Aether API — Stripe Billing (cloud only) =====
# Required when ENV_MODE=cloud.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ===== Frontend Build Args =====
# Passed via docker-compose build args. Must match API-side ENV_MODE.
# NEXT_PUBLIC_ENV_MODE=cloud
# NEXT_PUBLIC_BILLING_ENABLED=true
# NEXT_PUBLIC_AETHER_DEPLOYMENTS_ENABLED=false
# NEXT_PUBLIC_SUPABASE_URL=https://auth.example.com
# NEXT_PUBLIC_SUPABASE_ANON_KEY=CHANGE_ME
# NEXT_PUBLIC_BACKEND_URL=https://api.example.com
